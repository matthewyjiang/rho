{
  "packages": {
    ".": {
      "release-type": "rust",
      "package-name": "rho-coding-agent",
      "component": "rho-coding-agent",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "PKGBUILD"
        },
        {
          "type": "toml",
          "path": "crates/rho-provider/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.dependencies['rho-provider'].version"
        }
      ]
    }
  }
}
